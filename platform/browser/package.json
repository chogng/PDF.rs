{
  "name": "@pdf-rs/browser",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.18.0",
    "npm": "11.16.0"
  },
  "packageManager": "npm@11.16.0",
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "toolchain:check": "node scripts/check-toolchain.mjs",
    "protocol:check": "cargo run --quiet --manifest-path ../../Cargo.toml --package pdf-rs-protocol-codegen -- --check ../..",
    "typecheck": "tsc --project tsconfig.json --noEmit && tsc --project tsconfig.test.json --noEmit",
    "test:build": "npm run clean && tsc --project tsconfig.test.json",
    "test:unit": "npm run test:build && node --test .test-dist/test/*.test.js",
    "worker:test": "cargo test --locked --manifest-path ../../Cargo.toml --package pdf-rs-browser-worker",
    "abi:check": "node scripts/generate-native-worker-abi.mjs --check",
    "abi:generate": "node scripts/generate-native-worker-abi.mjs",
    "wasm:check": "cargo check --locked --manifest-path ../../Cargo.toml --package pdf-rs-browser-worker --target wasm32-unknown-unknown",
    "wasm:build": "npm run abi:check && tsc --project tsconfig.test.json && node scripts/build-native-worker.mjs",
    "wasm:verify": "node scripts/verify-native-worker.mjs",
    "wasm:fixture": "node scripts/test-native-worker-fixture.mjs",
    "purity:test": "node --test test/browser-product-purity.test.mjs",
    "purity:check": "node scripts/check-browser-product-purity.mjs",
    "purity:closure": "node scripts/prove-browser-product-closure.mjs",
    "test": "npm run protocol:check && npm run abi:check && npm run typecheck && npm run test:unit && npm run worker:test",
    "check": "npm run toolchain:check && npm test && npm run wasm:build && npm run wasm:verify && npm run wasm:fixture && npm run purity:test && npm run purity:check && npm run purity:closure"
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "typescript": "5.9.3"
  }
}
